[
  {
    "request": {
      "method": "POST",
      "url": "https://gmgard.com/api/PunchIn/Do",
      "headers": [
        {
          "name": ":method",
          "value": "POST"
        },
        {
          "name": ":authority",
          "value": "gmgard.com"
        },
        {
          "name": ":scheme",
          "value": "https"
        },
        {
          "name": ":path",
          "value": "/api/PunchIn/Do"
        },
        {
          "name": "accept",
          "value": "*/*"
        },
        {
          "name": "x-requested-with",
          "value": "XMLHttpRequest"
        },
        {
          "name": "content-type",
          "value": "application/json"
        },
        {
          "name": "origin",
          "value": "https://gmgard.com"
        },
        {
          "name": "sec-fetch-site",
          "value": "same-origin"
        },
        {
          "name": "sec-fetch-mode",
          "value": "cors"
        },
        {
          "name": "sec-fetch-dest",
          "value": "empty"
        },
        {
          "name": "referer",
          "value": "https://gmgard.com/"
        },
        {
          "name": "accept-encoding",
          "value": "gzip, deflate, br"
        },
        {
          "name": "accept-language",
          "value": "zh-CN,zh;q=0.9"
        },
        {
          "name": "cookie",
          "value": "{{cookie}}"
        }
      ],
      "cookies": [],
      "data": "{}",
      "mimeType": "application/json"
    },
    "rule": {
      "success_asserts": [
        {
          "re": "200",
          "from": "status"
        },
        {
          "re": "签到成功|success|duplicate|already|已签到|重复签到",
          "from": "content"
        }
      ],
      "failed_asserts": []
    }
  },
  {
    "comment": "输出签到结果",
    "request": {
      "method": "POST",
      "url": "api://util/unicode",
      "headers": [],
      "cookies": [],
      "data": "content=签到完成"
    },
    "rule": {
      "success_asserts": [
        {
          "re": "200",
          "from": "status"
        }
      ],
      "failed_asserts": [],
      "extract_variables": [
        {
          "name": "__log__",
          "re": "\"转换后\": \"(.*)\"",
          "from": "content"
        }
      ]
    }
  }
]