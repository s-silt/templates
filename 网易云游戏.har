[
  {
    "comment": "登录状态验证",
    "request": {
      "method": "GET",
      "url": "https://n.cg.163.com/api/v2/users/@me",
      "headers": [
        {
          "name": "Authorization",
          "value": " {{Authorization}}"
        },
        {
          "name": "user-agent",
          "value": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/93.0.4577.82 Safari/537.36"
        },
        {
          "name": "Connection",
          "value": "keep-alive"
        },
        {
          "name": "Accept-Encoding",
          "value": "gzip, deflate, br"
        },
        {
          "name": "Accept",
          "value": "*/*"
        }
      ],
      "cookies": []
    },
    "rule": {
      "success_asserts": [
        {
          "re": "200",
          "from": "status"
        }
      ],
      "failed_asserts": [],
      "extract_variables": []
    }
  },
  {
    "comment": "签到",
    "request": {
      "method": "POST",
      "url": "https://n.cg.163.com/api/v2/sign-today",
      "headers": [
        {
          "name": "user-agent",
          "value": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/93.0.4577.82 Safari/537.36"
        },
        {
          "name": "Authorization",
          "value": "{{Authorization}}"
        },
        {
          "name": "Connection",
          "value": "keep-alive"
        }
      ],
      "cookies": []
    },
    "rule": {
      "success_asserts": [
        {
          "re": "200",
          "from": "status"
        },
        {
          "re": "签到成功|success|duplicate|already|已签到|重复签到",
          "from": "content"
        }
      ],
      "failed_asserts": [],
      "extract_variables": []
    }
  },
  {
    "comment": "输出签到结果",
    "request": {
      "method": "POST",
      "url": "api://util/unicode",
      "headers": [],
      "cookies": [],
      "data": "content=签到完成"
    },
    "rule": {
      "success_asserts": [
        {
          "re": "200",
          "from": "status"
        }
      ],
      "failed_asserts": [],
      "extract_variables": [
        {
          "name": "__log__",
          "re": "\"转换后\": \"(.*)\"",
          "from": "content"
        }
      ]
    }
  }
]